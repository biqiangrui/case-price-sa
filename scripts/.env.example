SUPABASE_URL=https://rqqenomefezlslxfdbrn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

# Get this from 52hqb after logging in. It is sent as the API "token" header.
HQB_TOKEN=replace_with_52hqb_token

# Search and sync settings.
HQB_KEYWORD=IPHONE 17
HQB_LIMIT=100
HQB_SITE=hqb

# Optional: choose a better first image for products with crooked first photos.
# The number is zero-based, so 1 means "use the second image as the cover".
HQB_FEATURED_IMAGE_OVERRIDES={"12838421":1}

# 52hqb prices are usually CNY. The public site compares SAR, so convert CNY to SAR.
CNY_TO_SAR=0.52
